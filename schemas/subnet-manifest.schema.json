{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://metagraph.sh/schemas/subnet-manifest.schema.json",
  "title": "Metagraphed Subnet Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "netuid",
    "name",
    "slug",
    "status",
    "categories",
    "surfaces"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "netuid": {
      "type": "integer",
      "minimum": 0
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "status": {
      "enum": ["active", "inactive", "unknown"]
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "docs_url": {
      "type": "string",
      "format": "uri"
    },
    "source_repo": {
      "type": ["string", "null"],
      "format": "uri"
    },
    "dashboard_url": {
      "type": ["string", "null"],
      "format": "uri"
    },
    "website_url": {
      "type": ["string", "null"],
      "format": "uri"
    },
    "notes": {
      "type": "string"
    },
    "curation": {
      "$ref": "#/$defs/curation"
    },
    "links": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/link"
      }
    },
    "surfaces": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/surface"
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "kind",
        "url",
        "provider",
        "auth_required",
        "authority",
        "public_safe"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "enum": [
            "archive",
            "subtensor-rpc",
            "subtensor-wss",
            "subnet-api",
            "openapi",
            "sse",
            "sdk",
            "example",
            "website",
            "source-repo",
            "dashboard",
            "repo-registry",
            "docs",
            "data-artifact"
          ]
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "provider": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "auth_required": {
          "type": "boolean"
        },
        "authority": {
          "enum": [
            "official",
            "provider-claimed",
            "community",
            "registry-observed"
          ]
        },
        "public_safe": {
          "type": "boolean"
        },
        "schema_url": {
          "type": "string",
          "format": "uri"
        },
        "schema_status": {
          "enum": ["machine-readable", "ui-only", "not-captured"]
        },
        "source_urls": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          },
          "uniqueItems": true
        },
        "verification": {
          "$ref": "#/$defs/verification"
        },
        "quality_signals": {
          "type": "object",
          "additionalProperties": true
        },
        "rate_limit_notes": {
          "type": "string"
        },
        "probe": {
          "$ref": "#/$defs/probe"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "method", "expect"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "method": {
          "enum": ["GET", "HEAD", "JSON-RPC", "WSS-RPC"]
        },
        "expect": {
          "enum": ["json", "html", "sse", "any"]
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 30000
        }
      }
    },
    "curation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "review_state"],
      "properties": {
        "level": {
          "enum": [
            "native",
            "candidate-discovered",
            "machine-verified",
            "maintainer-reviewed",
            "adapter-backed"
          ]
        },
        "review_state": {
          "enum": [
            "unreviewed",
            "machine-generated",
            "maintainer-reviewed",
            "needs-review",
            "stale"
          ]
        },
        "reviewed_at": {
          "type": ["string", "null"]
        },
        "verified_at": {
          "type": ["string", "null"]
        },
        "source_count": {
          "type": "integer",
          "minimum": 0
        },
        "gap_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "url"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "source_url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": true,
      "required": ["classification", "verified_at"],
      "properties": {
        "classification": {
          "enum": [
            "live",
            "redirected",
            "auth-required",
            "dead",
            "unsafe",
            "unsupported",
            "rate-limited",
            "transient",
            "timeout",
            "content-mismatch"
          ]
        },
        "verified_at": {
          "type": "string"
        },
        "status_code": {
          "type": "integer"
        },
        "latency_ms": {
          "type": "integer"
        },
        "confidence_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "content_type": {
          "type": ["string", "null"]
        },
        "redirect_target": {
          "type": ["string", "null"],
          "format": "uri"
        }
      }
    }
  }
}
