{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://metagraph.sh/schemas/provider.schema.json",
  "title": "Metagraphed Provider",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "name",
    "kind",
    "website_url",
    "authority"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "enum": [
        "subnet-team",
        "infrastructure-provider",
        "data-provider",
        "docs-provider",
        "registry"
      ]
    },
    "website_url": {
      "type": "string",
      "format": "uri"
    },
    "docs_url": {
      "type": "string",
      "format": "uri"
    },
    "github_url": {
      "type": "string",
      "format": "uri"
    },
    "team_url": {
      "type": "string",
      "format": "uri"
    },
    "contact_url": {
      "type": "string",
      "format": "uri"
    },
    "authority": {
      "enum": ["official", "provider-claimed", "community", "registry-observed"]
    },
    "public_notes": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  }
}
